#!/bin/sh
# Pre-commit hook: auto-generate nav.json before each commit
# Install: git config core.hooksPath .githooks

set -e
cd "$(git rev-parse --show-toplevel)" || exit 1
echo "🔧 pre-commit: generating nav.json + sitemap.xml..."
python3 scripts/generate-nav.py
python3 scripts/generate-sitemap.py
git add docs/nav.json docs/sitemap.xml
